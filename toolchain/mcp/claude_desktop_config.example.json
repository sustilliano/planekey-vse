{
  "mcpServers": {
    "planekey-env-observer": {
      "command": "python",
      "args": [
        "mcp/planekey_env_observer_server.py"
      ],
      "env": {
        "PLANEKEY_HOME_BRIDGE_URL": "https://planekey.dev",
        "PLANEKEY_SERVICE_ID": "customer-product",
        "PLANEKEY_ENVIRONMENT_ID": "local-dev",
        "PLANEKEY_WORKSPACE_ROOT": "/path/to/customer/product",
        "PLANEKEY_MCP_ALLOW_SUBMIT": "false"
      }
    }
  }
}