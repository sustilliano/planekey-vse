{
  "name": "planekey-trust-layer",
  "displayName": "PlaneKey Trust Layer",
  "description": "One download, three surfaces: the PlaneKey toolchain (pk-client, pk-memory, Env-Observer MCP server) bundled into an IDE trust/control layer for AI-built software — use it in the editor, from the CLI, or over MCP.",
  "version": "0.6.0",
  "publisher": "planekey",
  "license": "SEE LICENSE IN LICENSE-PROPRIETARY",
  "engines": {
    "vscode": "^1.101.0"
  },
  "categories": ["Other", "Testing", "Linters"],
  "keywords": ["AI security", "DevSecOps", "integrity", "PlaneKey", "ConversationChain", "RootRabbit", "RepoGuard", "PixelGuard", "predictive", "inline completion"],
  "main": "./src/extension.js",
  "activationEvents": ["onStartupFinished"],
  "contributes": {
    "configuration": {
      "title": "PlaneKey",
      "properties": {
        "planekey.pkClientPath": { "type": "string", "default": "", "description": "Path to pk-client. Leave blank to use the copy BUNDLED with this extension (toolchain/pk-client) — zero-config." },
        "planekey.nodePath": { "type": "string", "default": "", "description": "Node.js interpreter used to run the bundled JS tools. Leave blank to use 'node' on PATH." },
        "planekey.projectRoot": { "type": "string", "default": "", "description": "Project root for PlaneKey scans. Leave blank to use the first workspace folder." },
        "planekey.reportRoot": { "type": "string", "default": "", "description": "PlaneKey reports folder. Leave blank to use <projectRoot>/reports." },
        "planekey.autoRefreshOnSave": { "type": "boolean", "default": false, "description": "Refresh current file risk after file saves." },
        "planekey.defaultBundleName": { "type": "string", "default": "ide-safe-bundle", "description": "Default name used for PlaneKey safe bundles." },
        "planekey.pkMemoryPath": { "type": "string", "default": "", "description": "Path to pk-memory. Leave blank to use the bundled copy." },
        "planekey.pkOperatorPath": { "type": "string", "default": "", "description": "Path to pk-operator executable." },
        "planekey.defaultMemoryName": { "type": "string", "default": "ide-memory", "description": "Default name for TMrFS/Rgano memory reports." },
        "planekey.mcpServerPath": { "type": "string", "default": "", "description": "Path to the PlaneKey Env-Observer MCP server (mcp/planekey_env_observer_server.py)." },
        "planekey.mcpPythonPath": { "type": "string", "default": "", "description": "Python interpreter for the MCP server. Leave blank to use 'python3'." },
        "planekey.homeBridgeUrl": { "type": "string", "default": "https://bridge.planekey.dev", "description": "Home Bridge URL (PLANEKEY_HOME_BRIDGE_URL)." },
        "planekey.serviceId": { "type": "string", "default": "ide-workspace", "description": "Service id for MCP observations (PLANEKEY_SERVICE_ID)." },
        "planekey.environmentId": { "type": "string", "default": "local-dev", "description": "Environment id for MCP observations (PLANEKEY_ENVIRONMENT_ID)." },
        "planekey.mcpAllowSubmit": { "type": "boolean", "default": false, "description": "Allow the MCP server to submit reports to the Home Bridge." },
        "planekey.predictive.enabled": { "type": "boolean", "default": true, "description": "Enable PlaneKey risk-aware predictive typing (inline completions). Local, no AI — suggestions come from your canon in the PlaneKey reports." },
        "planekey.predictive.minPrefix": { "type": "number", "default": 2, "minimum": 1, "maximum": 8, "description": "Minimum characters typed before predictive typing offers a suggestion." },
        "planekey.predictive.maxSuggestions": { "type": "number", "default": 5, "minimum": 1, "maximum": 15, "description": "Maximum number of inline predictive-typing suggestions to offer at once." },
        "planekey.memory.minCanonScore": { "type": "number", "default": 0.5, "minimum": 0, "maximum": 1, "description": "Minimum canon score (0.0–1.0) to surface a pk-memory suggestion." },
        "planekey.memory.maxRiskScore": { "type": "number", "default": 30, "minimum": 0, "maximum": 100, "description": "Maximum risk score for a pk-client pattern to be surfaced." },
        "planekey.memory.excludeSignals": { "type": "array", "default": ["agent_runtime_residue", "secret_or_private_material"], "description": "Never suggest patterns carrying these residue signals." },
        "planekey.db.enabled": { "type": "boolean", "default": true, "description": "Include suggestions from pk-client coherence pack." },
        "planekey.cache.ttl": { "type": "number", "default": 30, "description": "Predictive typing cache TTL in seconds." },
        "planekey.snapshotOnStartup": { "type": "boolean", "default": false, "description": "Run PlaneKey: Snapshot Workspace automatically when the extension activates (generates the full Rgano/TMrFS report set under the reports folder)." }
      }
    },
    "mcpServerDefinitionProviders": [
      { "id": "planekey.envObserver", "label": "PlaneKey Env-Observer" }
    ],
    "commands": [
      { "command": "planekey.openChat", "title": "PlaneKey: Open Chat", "category": "PlaneKey", "icon": "$(comment-discussion)" },
      { "command": "planekey.openChatDocs", "title": "PlaneKey: Open Chat — Docs Search", "category": "PlaneKey", "icon": "$(search)" },
      { "command": "planekey.openChatDirect", "title": "PlaneKey: Open Chat — Direct (E2EE)", "category": "PlaneKey", "icon": "$(mail)" },
      { "command": "planekey.openInbox", "title": "PlaneKey: Open Inbox", "category": "PlaneKey", "icon": "$(inbox)" },
      { "command": "planekey.refreshStatus", "title": "PlaneKey: Refresh Trust Status", "category": "PlaneKey" },
      { "command": "planekey.openPkClientTerminal", "title": "PlaneKey: Open pk-client Terminal", "category": "PlaneKey", "icon": "$(terminal)" },
      { "command": "planekey.indexCodebase", "title": "PlaneKey: Index Codebase Memory (Predictive Typing)", "category": "PlaneKey", "icon": "$(symbol-class)" },
      { "command": "planekey.buildDB", "title": "PlaneKey: Build Repo DB (Predictive Typing)", "category": "PlaneKey", "icon": "$(database)" },
      { "command": "planekey.snapshotWorkspace", "title": "PlaneKey: Snapshot Workspace (all reports)", "category": "PlaneKey", "icon": "$(device-camera)" },
      { "command": "planekey.refreshCache", "title": "PlaneKey: Refresh Predictive Cache", "category": "PlaneKey", "icon": "$(refresh)" },
      { "command": "planekey.showMemoryStats", "title": "PlaneKey: Show Memory Stats", "category": "PlaneKey", "icon": "$(graph)" },
      { "command": "planekey.togglePredictive", "title": "PlaneKey: Toggle Predictive Typing", "category": "PlaneKey", "icon": "$(eye)" },
      { "command": "planekey.runRepoGuard", "title": "PlaneKey: Run RepoGuard", "category": "PlaneKey" },
      { "command": "planekey.runPixelGuard", "title": "PlaneKey: Run PixelGuard", "category": "PlaneKey" },
      { "command": "planekey.runResidueMap", "title": "PlaneKey: Run ResidueGuard Map", "category": "PlaneKey" },
      { "command": "planekey.runRootRabbit", "title": "PlaneKey: Run RootRabbit Scan", "category": "PlaneKey" },
      { "command": "planekey.runSafetyNet", "title": "PlaneKey: Run SafetyNet", "category": "PlaneKey" },
      { "command": "planekey.attestDev", "title": "PlaneKey: Attest Dev Layer", "category": "PlaneKey" },
      { "command": "planekey.createSafeBundle", "title": "PlaneKey: Create Safe Bundle", "category": "PlaneKey" },
      { "command": "planekey.openReports", "title": "PlaneKey: Open Reports Folder", "category": "PlaneKey" },
      { "command": "planekey.setPkClientPath", "title": "PlaneKey: Set pk-client Path", "category": "PlaneKey" },
      { "command": "planekey.setProjectRoot", "title": "PlaneKey: Set Project Root", "category": "PlaneKey" },
      { "command": "planekey.runMemoryBuild", "title": "PlaneKey: Build TMrFS Memory", "category": "PlaneKey" },
      { "command": "planekey.runRganoScan", "title": "PlaneKey: Run Rgano Structure Scan", "category": "PlaneKey" },
      { "command": "planekey.runCanonRank", "title": "PlaneKey: Rank Canon Candidates", "category": "PlaneKey" },
      { "command": "planekey.runGraftPlan", "title": "PlaneKey: Build Graft Plan", "category": "PlaneKey" },
      { "command": "planekey.runOperatorDoctor", "title": "PlaneKey: Operator Doctor", "category": "PlaneKey" },
      { "command": "planekey.openIncident", "title": "PlaneKey: Open Operator Incident", "category": "PlaneKey" },
      { "command": "planekey.setPkMemoryPath", "title": "PlaneKey: Set pk-memory Path", "category": "PlaneKey" },
      { "command": "planekey.setPkOperatorPath", "title": "PlaneKey: Set pk-operator Path", "category": "PlaneKey" },
      { "command": "planekey.runFlightReport", "title": "PlaneKey: Submit Flight Report (to Home Bridge)", "category": "PlaneKey" },
      { "command": "planekey.runCanonAnalyze", "title": "PlaneKey: Submit Canon Analysis (to Home Bridge)", "category": "PlaneKey" },
      { "command": "planekey.runForensicsAttribution", "title": "PlaneKey: Submit Forensics Attribution (to Home Bridge)", "category": "PlaneKey" },
      { "command": "planekey.runRganoPacket", "title": "PlaneKey: Submit Rgano Signature Packet (to Home Bridge)", "category": "PlaneKey" },
      { "command": "planekey.runRootRabbitHealth", "title": "PlaneKey: Submit RootRabbit Health (to Home Bridge)", "category": "PlaneKey" },
      { "command": "planekey.runCoherencePack", "title": "PlaneKey: Emit Coherence Pack (60-sec AI grounding)", "category": "PlaneKey" },
      { "command": "planekey.runTrustState", "title": "PlaneKey: Show Trust State (from provenance/)", "category": "PlaneKey" },
      { "command": "planekey.runRpgReachable", "title": "PlaneKey: RPG Reachability (route -> target symbol)", "category": "PlaneKey" },
      { "command": "planekey.runMatrixCarryForward", "title": "PlaneKey: Matrix Carry-Forward (between two versions)", "category": "PlaneKey" },
      { "command": "planekey.runDecisionsDistribution", "title": "PlaneKey: Decisions Distribution (canon + forensics + route health)", "category": "PlaneKey" },
      { "command": "planekey.runOperatorReplay", "title": "PlaneKey: Operator Actions Replay (bridge intent log)", "category": "PlaneKey" },
      { "command": "planekey.setMcpServerPath", "title": "PlaneKey: Set MCP Server Path", "category": "PlaneKey" },
      { "command": "planekey.refreshMcpServer", "title": "PlaneKey: Refresh MCP Server (re-register with the MCP host)", "category": "PlaneKey" },
      { "command": "planekey.showCliSetup", "title": "PlaneKey: Show CLI Setup (use the bundled pk-client from your terminal)", "category": "PlaneKey" }
    ],
    "menus": {
      "commandPalette": [
        { "command": "planekey.openChat" },
        { "command": "planekey.openChatDocs" },
        { "command": "planekey.openChatDirect" },
        { "command": "planekey.openInbox" },
        { "command": "planekey.refreshStatus" },
        { "command": "planekey.openPkClientTerminal" },
        { "command": "planekey.indexCodebase" },
        { "command": "planekey.buildDB" },
        { "command": "planekey.snapshotWorkspace" },
        { "command": "planekey.refreshCache" },
        { "command": "planekey.showMemoryStats" },
        { "command": "planekey.togglePredictive" },
        { "command": "planekey.runRepoGuard" },
        { "command": "planekey.runPixelGuard" },
        { "command": "planekey.runResidueMap" },
        { "command": "planekey.runRootRabbit" },
        { "command": "planekey.runSafetyNet" },
        { "command": "planekey.attestDev" },
        { "command": "planekey.createSafeBundle" },
        { "command": "planekey.openReports" },
        { "command": "planekey.setPkClientPath" },
        { "command": "planekey.setProjectRoot" },
        { "command": "planekey.runMemoryBuild" },
        { "command": "planekey.runRganoScan" },
        { "command": "planekey.runCanonRank" },
        { "command": "planekey.runGraftPlan" },
        { "command": "planekey.runOperatorDoctor" },
        { "command": "planekey.openIncident" },
        { "command": "planekey.setPkMemoryPath" },
        { "command": "planekey.setPkOperatorPath" },
        { "command": "planekey.runFlightReport" },
        { "command": "planekey.runCanonAnalyze" },
        { "command": "planekey.runForensicsAttribution" },
        { "command": "planekey.runRganoPacket" },
        { "command": "planekey.runRootRabbitHealth" },
        { "command": "planekey.runCoherencePack" },
        { "command": "planekey.runTrustState" },
        { "command": "planekey.runRpgReachable" },
        { "command": "planekey.runMatrixCarryForward" },
        { "command": "planekey.runDecisionsDistribution" },
        { "command": "planekey.runOperatorReplay" },
        { "command": "planekey.setMcpServerPath" },
        { "command": "planekey.refreshMcpServer" },
        { "command": "planekey.showCliSetup" }
      ],
      "explorer/context": [
        { "command": "planekey.runRepoGuard", "group": "planekey@1" },
        { "command": "planekey.runPixelGuard", "group": "planekey@2" },
        { "command": "planekey.runSafetyNet", "group": "planekey@3" },
        { "command": "planekey.runMemoryBuild", "group": "planekey@4" },
        { "command": "planekey.runRganoScan", "group": "planekey@5" },
        { "command": "planekey.runOperatorDoctor", "group": "planekey@6" },
        { "command": "planekey.indexCodebase", "group": "planekey@7", "when": "explorerResourceIsFolder" }
      ],
      "editor/context": [
        { "command": "planekey.refreshStatus", "group": "planekey@1" }
      ],
      "view/title": [
        { "command": "planekey.openChat", "when": "view == planekeyTrustView", "group": "navigation@1" },
        { "command": "planekey.openInbox", "when": "view == planekeyTrustView", "group": "navigation@2" },
        { "command": "planekey.openChat", "when": "view == planekeyActionsView", "group": "navigation@1" },
        { "command": "planekey.openInbox", "when": "view == planekeyActionsView", "group": "navigation@2" },
        { "command": "planekey.snapshotWorkspace", "when": "view == planekeyActionsView", "group": "navigation@3" }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        { "id": "planekey", "title": "PlaneKey", "icon": "assets/planekey.svg" }
      ]
    },
    "views": {
      "planekey": [
        { "id": "planekeyTrustView", "name": "Trust Layer" },
        { "id": "planekeyActionsView", "name": "Actions" }
      ]
    }
  },
  "scripts": {
    "smoke": "node -c src/extension.js && node -c src/providers/predictiveTypingProvider.js && node -c src/providers/predictiveIndex.js && node -c src/panels/chatPanel.js && node -c src/panels/snapshotCard.js && node -c toolchain/pk-memory/pk-memory.js"
  }
}
